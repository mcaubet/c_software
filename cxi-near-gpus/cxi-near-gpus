#!/usr/bin/env bash
set -euo pipefail

declare -A CXI_BY_NUMA
declare -A GPU_NUMA

# Build NUMA -> CXI map
for d in /sys/class/cxi/cxi*; do
    [[ -e "$d" ]] || continue
    cxi=$(basename "$d")
    numa=$(< "$d/device/numa_node")
    [[ "$numa" =~ ^[0-9]+$ ]] || continue
    CXI_BY_NUMA["$numa"]="$cxi"
done

# Read GPU -> NUMA Affinity from nvidia-smi topo -m
while IFS= read -r line; do
    [[ "$line" =~ ^GPU[0-9]+[[:space:]] ]] || continue
    read -r -a fields <<< "$line"
    gpu="${fields[0]#GPU}"

    nfields="${#fields[@]}"
    (( nfields >= 3 )) || continue

    # Penultimate field = NUMA Affinity
    numa="${fields[$((nfields - 2))]}"
    [[ "$numa" =~ ^[0-9]+$ ]] || continue

    GPU_NUMA["$gpu"]="$numa"
done < <(nvidia-smi topo -m)

# Determine which GPUs are visible/reserved for this step
declare -a gpu_list
if [[ -n "${CUDA_VISIBLE_DEVICES:-}" ]]; then
    IFS=',' read -r -a gpu_list <<< "$CUDA_VISIBLE_DEVICES"
else
    # Fallback: use all GPUs found in topo output
    mapfile -t gpu_list < <(printf '%s\n' "${!GPU_NUMA[@]}" | sort -n)
fi

# Build ordered FI_LNX_PROV_LINKS string
links=()
for gpu in "${gpu_list[@]}"; do
    [[ "$gpu" =~ ^[0-9]+$ ]] || continue
    numa="${GPU_NUMA[$gpu]:-}"
    [[ -n "$numa" ]] || continue
    cxi="${CXI_BY_NUMA[$numa]:-}"
    [[ -n "$cxi" ]] || continue
    links+=("shm+cxi:${cxi}")
done

# Print only the export line
(
    IFS='|'
    printf 'export FI_LNX_PROV_LINKS="%s"\n' "${links[*]}"
)
