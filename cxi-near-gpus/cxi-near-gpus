#!/usr/bin/env bash
set -u
set -o pipefail

echo "host=$(hostname)"
echo "jobid=${SLURM_JOB_ID:-}"
echo "stepid=${SLURM_STEP_ID:-}"
echo "CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES:-<unset>}"
echo "SLURM_STEP_GPUS=${SLURM_STEP_GPUS:-<unset>}"
echo

echo "== CXI devices =="
for d in /sys/class/cxi/cxi*; do
    cxi=$(basename "$d")
    numa=$(cat "$d/device/numa_node" 2>/dev/null || echo -1)
    pci=$(basename "$(readlink -f "$d/device")")
    printf "%s numa=%s pci=%s\n" "$cxi" "$numa" "$pci"
done
echo

echo "== GPU topology =="
nvidia-smi topo -m
echo

echo "== GPU -> CXI expected mapping from NUMA Affinity =="
nvidia-smi topo -m | awk '
BEGIN {
    while (("find /sys/class/cxi -maxdepth 1 -type l -name \"cxi*\" | sort" | getline path) > 0) {
        cmd = "basename " path
        cmd | getline cxi
        close(cmd)

        cmd = "cat " path "/device/numa_node 2>/dev/null"
        cmd | getline numa
        close(cmd)

        cxi_by_numa[numa] = cxi
    }
}
/^GPU[0-9]+[[:space:]]/ {
    gpu=$1
    numa=$(NF-1)   # NUMA Affinity column
    gsub(/[^0-9]/, "", numa)
    if (numa != "" && (numa in cxi_by_numa))
        printf "%s -> numa %s -> %s\n", gpu, numa, cxi_by_numa[numa]
    else
        printf "%s -> numa %s -> no matching cxi found\n", gpu, numa
}'
